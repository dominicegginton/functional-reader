{
  "name": "functional-reader",
  "version": "2.1.1",
  "description": "A purely functional dependency injection library for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "lint": "eslint \"src/**/*.ts\" \"examples/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" \"examples/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "example:basic": "npx jiti examples/basic.ts",
    "example:full": "npx jiti examples/full-example.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.8.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-functional": "9.0.4",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.4.2",
    "jiti": "2.7.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3"
  }
}
